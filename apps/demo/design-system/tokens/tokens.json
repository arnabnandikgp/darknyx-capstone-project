{
  "$schema": "https://design-tokens.org/schema.json",
  "brand": {
    "name": "DarkNyx",
    "tagline": "Settle in the dark. Prove in the light.",
    "category": "Darkpool protocol — TEE + ZK",
    "wordmark": "darknyx"
  },
  "color": {
    "ink":     { "value": "#0a0a0d", "type": "color", "description": "Primary brand. Near-black. ~95% of dark surfaces." },
    "chalk":   { "value": "#f5f3ee", "type": "color", "description": "Primary paper. Warm off-white. ~95% of light surfaces." },
    "slate":   { "value": "#6b6b74", "type": "color", "description": "Mid-tone. Secondary text, dividers." },
    "fog":     { "value": "#aeacb0", "type": "color", "description": "Light secondary text." },
    "graphite":{ "value": "#1a1a20", "type": "color", "description": "Elevated surface in dark mode." },
    "accent":  { "value": "oklch(0.62 0.14 260)", "type": "color", "description": "Cobalt. Marketing-only accent. Never used in the mark." },
    "signal": {
      "green": { "value": "#5fb85f", "type": "color", "description": "Status: matched / live / healthy." },
      "amber": { "value": "#d9a441", "type": "color", "description": "Status: pending / attesting." },
      "red":   { "value": "#c84545", "type": "color", "description": "Status: failed / cancelled." }
    }
  },
  "type": {
    "family": {
      "display": { "value": "'Space Grotesk', 'Inter', system-ui, sans-serif" },
      "body":    { "value": "'Space Grotesk', 'Inter', system-ui, sans-serif" },
      "mono":    { "value": "'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace" }
    },
    "weight": {
      "regular":  { "value": 400 },
      "medium":   { "value": 500 },
      "semibold": { "value": 600 },
      "bold":     { "value": 700 }
    },
    "scale": {
      "xs":  { "value": "11px", "lineHeight": 1.4 },
      "sm":  { "value": "13px", "lineHeight": 1.5 },
      "md":  { "value": "15px", "lineHeight": 1.55 },
      "lg":  { "value": "18px", "lineHeight": 1.5 },
      "xl":  { "value": "24px", "lineHeight": 1.3, "tracking": "-0.02em" },
      "2xl": { "value": "32px", "lineHeight": 1.15, "tracking": "-0.025em" },
      "3xl": { "value": "44px", "lineHeight": 1.05, "tracking": "-0.03em" },
      "4xl": { "value": "64px", "lineHeight": 1.0,  "tracking": "-0.035em" }
    }
  },
  "space": {
    "0":  { "value": "0px" },
    "1":  { "value": "4px" },
    "2":  { "value": "8px" },
    "3":  { "value": "12px" },
    "4":  { "value": "16px" },
    "5":  { "value": "24px" },
    "6":  { "value": "32px" },
    "7":  { "value": "48px" },
    "8":  { "value": "64px" },
    "9":  { "value": "96px" },
    "10": { "value": "128px" }
  },
  "radius": {
    "none": { "value": "0px" },
    "xs":   { "value": "2px",  "description": "Default. Institutional, sharp." },
    "sm":   { "value": "4px" },
    "md":   { "value": "8px" },
    "pill": { "value": "9999px" }
  },
  "border": {
    "hairline": { "value": "1px solid rgba(245,243,238,0.08)", "description": "Dark surface dividers." },
    "rule":     { "value": "1px solid rgba(10,10,13,0.08)",    "description": "Light surface dividers." }
  },
  "shadow": {
    "none":   { "value": "none", "description": "Default. The system avoids drop shadows." },
    "lift":   { "value": "0 8px 20px rgba(0,0,0,0.18)", "description": "Use sparingly — physical objects only (e.g. a card on a textured backdrop)." }
  },
  "motion": {
    "duration": {
      "instant": { "value": "80ms" },
      "fast":    { "value": "160ms" },
      "base":    { "value": "240ms" },
      "slow":    { "value": "400ms" }
    },
    "easing": {
      "standard": { "value": "cubic-bezier(0.2, 0.0, 0.0, 1.0)", "description": "Default — eased exit." },
      "entrance": { "value": "cubic-bezier(0.0, 0.0, 0.2, 1.0)" },
      "exit":     { "value": "cubic-bezier(0.4, 0.0, 1.0, 1.0)" }
    }
  },
  "logo": {
    "minSize":     { "value": "16px" },
    "microBelow":  { "value": "24px", "description": "Use micro variant (single horizon line) at this size or smaller." },
    "clearspace":  { "value": "x", "description": "x = height of the half-moon. Apply on all sides." }
  }
}
